[92m16:38:48 - openhands:INFO[0m: local_runtime.py:739 - server: '\n###PS1JSON###\n{\n  "pid": "",\n  "exit_code": "130",\n  "username": "yjh",\n  "hostname": "server3090",\n  "working_dir": "/home/yjh/openhands_workspace_v5/v5_dpi_20260328_163139",\n  "py_interpreter_path": "/home/yjh/local_openhands_env/bin/python"\n}\n###PS1END###\ncat > /home/yjh/openhands_workspace_v5/v5_dpi_20260328_163139/toy_examples.py << \'PYEOF\'\n"""\nDPI Toy Examples: 2D distribution learning with Real-NVP.\nReproduces Figure 1 from the paper.\n"""\nimport torch\nimport torch.nn as nn\nimport numpy as np\nimport json\nimport sys\nimport time\nfrom real_nvp import RealNVP\ntorch.manual_seed(42)\nnp.random.seed(42)\ndef gaussian_mixture_potential(x):\n    """Gaussian mixture with 4 modes."""\n    mus = [torch.tensor([2.0, 2.0]), torch.tensor([-2.0, 2.0]),\n           torch.tensor([2.0, -2.0]), torch.tensor([-2.0, -2.0])]\n    sigma = 0.5\n    log_probs = torch.stack([\n        -0.5 * torch.sum((x - mu.unsqueeze(0))**2, dim=1) / sigma**2\n        for mu in mus\n    ], dim=1)\n    max_lp = log_probs.max(dim=1, keepdim=True).values\n    log_mixture = max_lp.squeeze(1) + torch.log(torch.sum(torch.exp(log_probs - max_lp), dim=1))\n    return -log_mixture\ndef bowtie_potential(x):\n    """Bowtie-shaped distribution."""\n    x1, x2 = x[:, 0], x[:, 1]\n    sigma = 0.3\n    d1 = (x2 - x1) / np.sqrt(2)\n    d2 = (x2 + x1) / np.sqrt(2)\n    log_p1 = -0.5 * d1**2 / sigma**2 - 0.5 * (x1**2 + x2**2) / 4.0\n    log_p2 = -0.5 * d2**2 / sigma**2 - 0.5 * (x1**2 + x2**2) / 4.0\n    max_lp = torch.maximum(log_p1, log_p2)\n    log_mixture = max_lp + torch.log(torch.exp(log_p1 - max_lp) + torch.exp(log_p2 - max_lp))\n    return -log_mixture\ndef sinusoidal_potential(x):\n    """Sinusoidal-shaped distribution."""\n    x1, x2 = x[:, 0], x[:, 1]\n    sigma = 0.4\n    d = x2 - torch.sin(x1 * np.pi / 2)\n    log_p = -0.5 * d**2 / sigma**2 - 0.5 * x1**2 / 4.0\n    return -log_p\ndef estimate_kl_divergence(model, potential_fn, n_samples=10000, grid_range=5.0, n_grid=200):\n    """Estimate KL(q || p) using samples from q and the known potential."""\n    x_lin = torch.linspace(-grid_range, grid_range, n_grid)\n    dx = (2 * grid_range / n_grid)\n    xx, yy = torch.meshgrid(x_lin, x_lin, indexing=\'ij\')\n    grid = torch.stack([xx.flatten(), yy.flatten()], dim=1)\n    neg_potential = -potential_fn(grid)\n    log_Z = torch.logsumexp(neg_potential, dim=0) + 2 * np.log(dx)\n    with torch.no_grad():\n        z = torch.randn(n_samples, 2)\n        x, log_det = model(z)\n        log_pi_z = -0.5 * torch.sum(z**2, dim=1) - np.log(2 * np.pi)\n        log_q = log_pi_z - log_det\n        log_p = -potential_fn(x) - log_Z\n        kl = torch.mean(log_q - log_p)\n    return kl.item()\ndef train_dpi_toy(potential_fn, beta=1.0, n_layers=16, hidden_dim=64, n_hidden=2,\n                  n_epochs=2000, batch_size=64, lr=5e-4, verbose=True):\n    """Train DPI on a 2D toy distribution."""\n    model = RealNVP(dim=2, n_layers=n_layers, hidden_dim=hidden_dim, n_hidden=n_hidden)\n    optimizer = torch.optim.Adam(model.parameters(), lr=lr)\n\n    for epoch in range(n_epochs):\n        z = torch.randn(batch_size, 2)\n        x, log_det = model(z)\n        potential = potential_fn(x)\n        loss = torch.mean(potential - beta * log_det)\n\n        optimizer.zero_grad()\n        loss.backward()\n        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n        optimizer.step()\n\n        if verbose and (epoch + 1) % 500 == 0:\n            with torch.no_grad():\n                kl = estimate_kl_divergence(model, potential_fn, n_samples=5000)\n            print(f"  Epoch {epoch+1}/{n_epochs}, Loss: {loss.item():.4f}, KL: {kl:.4f}")\n\n    return model\nif __name__ == "__main__":\n    # Quick timing test\n    print("=== Quick timing test ===")\n    t0 = time.time()\n    torch.manual_seed(42)\n    model = train_dpi_toy(gaussian_mixture_potential, beta=1.0, n_epochs=200, verbose=False)\n    t1 = time.time()\n    print(f"200 epochs took {t1-t0:.1f}s")\n    kl = estimate_kl_divergence(model, gaussian_mixture_potential)\n    print(f"KL after 200 epochs: {kl:.4f}")\n\n    # Estimate time for full run\n    est_time = (t1 - t0) / 200 * 2000 * 10 * 3 / 60\n    print(f"Estimated time for full experiment: {est_time:.1f} minutes")\nPYEOF\n\n###PS1JSON###\n{\n  "pid": "",\n  "exit_code": "0",\n  "username": "yjh",\n  "hostname": "server3090",\n  "working_dir": "/home/yjh/openhands_workspace_v5/v5_dpi_20260328_163139",\n  "py_interpreter_path": "/home/yjh/local_openhands_env/bin/python"\n}\n###PS1END###\ncd /home/yjh/openhands_workspace_v5/v5_dpi_20260328_163139 && python3 toy_examples.py 2>&1\n^L=== Quick timing test ===\n/home/yjh/local_openhands_env/lib/python3.12/site-packages/torch/autograd/graph.py:869: UserWarning: CUDA initialization: The NVIDIA driver on your system is too old (found version 12020). Please update your GPU driver by downloading and installing a new version from the URL: http://www.nvidia.com/Download/index.aspx Alternatively, go to: https://pytorch.org to install a PyTorch version that has been compiled with your version of the CUDA driver. (Triggered internally at /pytorch/c10/cuda/CUDAFunctions.cpp:119.)\n  return Variable._execution_engine.run_backward(  # Calls into the C++ engine to run the backward pass\ncd /home/yjh/openhands_workspace_v5/v5_dpi_20260328_163139 && python3 toy_examples.py'
