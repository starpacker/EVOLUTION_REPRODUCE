[92m16:59:02 - openhands:INFO[0m: local_runtime.py:739 - server: '\n###PS1JSON###\n{\n  "pid": "",\n  "exit_code": "0",\n  "username": "yjh",\n  "hostname": "server3090",\n  "working_dir": "/home/yjh/openhands_workspace_v5/test_b1_run1_flfm_20260329_164220",\n  "py_interpreter_path": "/home/yjh/local_openhands_env/bin/python"\n}\n###PS1END###\ncat > /home/yjh/openhands_workspace_v5/test_b1_run1_flfm_20260329_164220/flfm_simulation.py << \'PYEOF\'\n"""\nComplete FLFM simulation: PSF generation, forward model, and Richardson-Lucy reconstruction.\nMatches paper parameters: 40x/0.95NA, fFL=75mm, MLA 600μm pitch, fMLA=16.8mm\n"""\nimport numpy as np\nfrom scipy.special import j0\nfrom scipy.signal import fftconvolve\nfrom scipy.ndimage import zoom\nimport time\nimport json\n # ============================================================\n# System Parameters\n# ============================================================\nlam = 680e-9       # emission wavelength [m]\nNA = 0.95\nM = 40\nn = 1.0\nf_obj = 200e-3 / M  # ~5mm\nalpha = np.arcsin(NA / n)\nk = 2 * np.pi * n / lam\n P = 6.5e-6         # camera pixel [m]\nD_cam = 13.3e-3\nf_FL = 75e-3\nf_MLA = 16.8e-3\nd_MLA = 600e-6\n1M_T = M * f_MLA / f_FL  # 8.96\nD_pupil = 2 * NA * f_FL / M  # 3.5625 mm\nNA_ML = d_MLA / (2 * f_MLA)  # 0.01786\n)# Theoretical values\nR_xy_theory = lam * (D_pupil/d_MLA) / (2 * NA)  # 2.12 μm\nR_z_theory = 4.70e-6  # from paper\nFOV_theory = d_MLA * f_FL / f_MLA / M  # 66.96 μm\n # Reconstruction grid\ndelta_xy = 0.943e-6  # object space voxel [m]\ndelta_z = 0.5e-6     # axial step [m]\nf# Camera pixel in object space\ncam_pix_obj = P / M_T  # 0.725 μm\n print("=== System Parameters ===")\nprint(f"M_T = {M_T:.2f}")\nprint(f"D_pupil = {D_pupil*1e3:.4f} mm")\nprint(f"NA_ML = {NA_ML:.6f}")\nprint(f"R_xy = {R_xy_theory*1e6:.2f} μm")\nprint(f"FOV = {FOV_theory*1e6:.2f} μm")\nprint(f"Camera pixel in object space = {cam_pix_obj*1e6:.3f} μm")\nprint(f"Diffraction spot on camera = {lam/(2*NA_ML)*1e6:.1f} μm = {lam/(2*NA_ML)/P:.1f} pixels")\nl# ============================================================\n# MLA geometry - 5x5 grid\n# ============================================================\nml_indices = []\nfor i in range(-2, 3):\n    for j in range(-2, 3):\n        cx = i * d_MLA\n        cy = j * d_MLA\n        dist = np.sqrt(cx**2 + cy**2)\n        if dist <= D_pupil/2 + d_MLA/2:\n            ml_indices.append((i, j))\n)print(f"Number of microlenses: {len(ml_indices)}")\n# Should be 21 (5x5 minus 4 corners that are outside the circular pupil)\n# Actually with D_pupil/2 = 1.78mm, corner distance = sqrt(2)*1.2mm = 1.697mm < 1.78mm\n# So all 25 should fit\n# With d_MLA/2 tolerance: all 25 definitely fit\nL# ============================================================\n# PSF Computation - Wave Optics Model\n# ============================================================\ndef compute_nip_field(p, N_grid, dx_nip, n_theta=100):\n    """Compute complex field at NIP using Debye integral for point source at p."""\n    p1, p2, p3 = p\n    coords = (np.arange(N_grid) - N_grid//2) * dx_nip\n    X, Y = np.meshgrid(coords, coords)\n\n    u = 4 * k * p3 * np.sin(alpha/2)**2\n    prefactor = np.exp(-1j * u / (4 * np.sin(alpha/2)**2))\n\n    theta_vals = np.linspace(1e-10, alpha, n_theta)\n    dtheta = theta_vals[1] - theta_vals[0]\n\n    r_obj = np.sqrt((X/M - p1)**2 + (Y/M - p2)**2)\n    v = k * r_obj * np.sin(alpha)\n\n    result = np.zeros((N_grid, N_grid), dtype=complex)\n    for theta in theta_vals:\n        P_theta = np.cos(theta)**0.5\n        phase = np.exp(1j * u * np.sin(theta/2)**2 / (2 * np.sin(alpha/2)**2))\n        integrand = P_theta * phase * j0(v * np.sin(theta) / np.sin(alpha)) * np.sin(theta)\n        result += integrand * dtheta\n\n    return prefactor * result\njedef compute_flfm_psf(p, cam_npix=210, n_theta=80):\n    """\n    Compute FLFM PSF on camera for point source at p=(p1,p2,p3) in object space.\n    Returns intensity on camera grid of cam_npix x cam_npix at pixel size P.\n    """\n    # We need the NIP grid to be such that after FFT, the MLA plane grid\n    # has pixel size that allows proper sampling of the MLA structure.\n    #\n    # After FFT: dx_mla = lambda * f_FL / (N_grid * dx_nip)\n    # We want dx_mla to be small enough to resolve the microlens aperture.\n    # d_MLA = 600 μm, need at least ~20 pixels per microlens: dx_mla ~ 30 μm\n    #\n    # Also, the camera pixel is P = 6.5 μm, and the image behind each microlens\n    # is formed at distance f_MLA from MLA. The camera grid pixel maps to\n    # dx_cam_at_mla = P (since relay is 1:1, camera sees the back focal plane of MLA).\n    #\n    # For the angular spectrum propagation from MLA to camera:\n    # The grid stays the same size, so dx_cam = dx_mla after propagation.\n    # We want dx_cam ≈ P = 6.5 μm for direct comparison.\n\n    # Target: dx_mla ≈ P = 6.5 μm\n    # dx_mla = lambda * f_FL / (N_grid * dx_nip)\n    # Need N_grid * dx_nip = lambda * f_FL / P = 680e-9 * 75e-3 / 6.5e-6 = 7846 μm\n\n    target_nip_extent = lam * f_FL / P  # 7.846 mm total NIP extent\n\n    # Choose N_grid as power of 2 for FFT efficiency\n    # Also need dx_nip small enough to resolve the Airy disk at NIP\n    # Airy radius at NIP ≈ 0.61 * lam / NA * M = 17.5 μm (in NIP coordinates)\n    airy_nip = 0.61 * lam * M / NA  # ~28.7 μm\n\n    # With N_grid = 512: dx_nip = 7846/512 = 15.3 μm (OK, ~2 pixels per Airy)\n    # With N_grid = 1024: dx_nip = 7846/1024 = 7.66 μm (better, ~4 pixels per Airy)\n    # With N_grid = 2048: dx_nip = 7846/2048 = 3.83 μm (good)\n\n    N_grid = 1024  # balance between speed and accuracy\n    dx_nip = target_nip_extent / N_grid\n\n    # Compute NIP field\n    U_nip = compute_nip_field(p, N_grid, dx_nip, n_theta)\n\n    # OFT to MLA plane\n    dx_mla = lam * f_FL / (N_grid * dx_nip)\n    U_mla = np.fft.fftshift(np.fft.fft2(np.fft.ifftshift(U_nip))) * dx_nip**2\n\n    # MLA plane coordinates\n    mla_coords = (np.arange(N_grid) - N_grid//2) * dx_mla\n    X_mla, Y_mla = np.meshgrid(mla_coords, mla_coords)\n\n    # Apply MLA modulation\n    U_after_mla = np.zeros_like(U_mla)\n    for (i_ml, j_ml) in ml_indices:\n        cx = i_ml * d_MLA\n        cy = j_ml * d_MLA\n        dx_fc = X_mla - cx\n        dy_fc = Y_mla - cy\n        mask = (np.abs(dx_fc) <= d_MLA/2) & (np.abs(dy_fc) <= d_MLA/2)\n        r2 = dx_fc**2 + dy_fc**2\n        phase = np.exp(-1j * k / (2 * f_MLA) * r2)\n        U_after_mla += U_mla * mask * phase\n\n    # Fresnel propagation to camera (distance = f_MLA)\n    dfx = 1.0 / (N_grid * dx_mla)\n    fx = (np.arange(N_grid) - N_grid//2) * dfx\n    FX, FY = np.meshgrid(fx, fx)\n    freq_sq = FX**2 + FY**2\n\n    prop_mask = freq_sq < (1/lam)**2\n    H_prop = np.zeros_like(FX, dtype=complex)\n    H_prop[prop_mask] = np.exp(1j * 2 * np.pi * f_MLA *\n                                np.sqrt((1/lam)**2 - freq_sq[prop_mask]))\n\n    U_ft = np.fft.fftshift(np.fft.fft2(np.fft.ifftshift(U_after_mla)))\n    U_cam = np.fft.fftshift(np.fft.ifft2(np.fft.ifftshift(U_ft * H_prop)))\n\n    I_cam = np.abs(U_cam)**2\n\n    # The grid pixel size is dx_mla ≈ P\n    # Crop to cam_npix x cam_npix centered\n    c = N_grid // 2\n    half = cam_npix // 2\n    I_crop = I_cam[c-half:c-half+cam_npix, c-half:c-half+cam_npix]\n\n    return I_crop, dx_mla\nSadef compute_psf_stack(z_values, cam_npix=210, n_theta=80):\n    """Compute PSF stack for on-axis emitter at different depths."""\n    psf_stack = []\n    for z in z_values:\n        print(f"  Computing PSF at z = {z*1e6:.1f} μm...")\n        psf, dx = compute_flfm_psf((0, 0, z), cam_npix, n_theta)\n        psf_stack.append(psf)\n    return np.array(psf_stack), dx\nin# ============================================================\n# Richardson-Lucy Deconvolution\n# ============================================================\ndef forward_project(volume, psf_stack):\n    """Forward project 3D volume to 2D camera image using PSF stack."""\n    image = np.zeros_like(psf_stack[0])\n    for z_idx in range(volume.shape[0]):\n        if np.any(volume[z_idx] > 0):\n            image += fftconvolve(volume[z_idx], psf_stack[z_idx], mode=\'same\')\n    return image\nredef back_project(image, psf_stack):\n    """Back project 2D camera image to 3D volume."""\n    volume = np.zeros((len(psf_stack),) + image.shape)\n    for z_idx in range(len(psf_stack)):\n        # PSF\' is PSF rotated by 180 degrees\n        psf_rot = psf_stack[z_idx][::-1, ::-1]\n        volume[z_idx] = fftconvolve(image, psf_rot, mode=\'same\')\n    return volume\n# def richardson_lucy_3d(camera_image, psf_stack, n_iter=5):\n    """\n    3D Richardson-Lucy deconvolution for FLFM.\n    camera_image: 2D measured image\n    psf_stack: 3D PSF stack (n_z, ny, nx)\n    """\n    n_z = psf_stack.shape[0]\n    ny, nx = camera_image.shape\n\n    # Normalize PSFs\n    psf_norm = psf_stack.copy()\n    total = psf_norm.sum()\n    if total > 0:\n        psf_norm /= total\n\n    # Initialize volume estimate\n    g = np.ones((n_z, ny, nx)) * camera_image.mean()\n\n    eps = 1e-12\n\n    for it in range(n_iter):\n        # Forward projection: Hg\n_fwhm(profile_z, delta_z * 1e6)\n\n    print(f"\\nFWHM measure        Hg = forward_project(g, psf_norm)\n        Hg = np.maximum(Hg, eps)\n\n        # Ratio\n        ratio = camera_image / Hg\n\n        # Back projection of ratio\n        correction = back_project(ratio, psf_norm)\n\n        # Also need normalization: H^T * ones\n        # For RL: g_new = g * (H^T * (O / Hg)) / (H^T * 1)\n        # The standard RL update\n        HT_ones = back_project(np.ones_like(camera_image), psf_norm)\n        HT_ones = np.maximum(HT_ones, eps)\n\n        g = g * correction / HT_ones\n        g = np.maximum(g, 0)\n\n        residual = np.sum((Hg - camera_image)**2)\n        print(f"  Iteration {it+1}/{n_iter}, residual = {residual:.6e}")\n\ne    return g\nendef measure_fwhm(profile, pixel_size):\n    """Measure FWHM of a 1D profile."""\n    profile = profile - profile.min()\n    half_max = profile.max() / 2\n    above = profile >= half_max\n    indices = np.where(above)[0]\n    if len(indices) < 2:\n        return 0\n    fwhm_pixels = indices[-1] - indices[0]\n    return fwhm_pixels * pixel_size\n4.# ============================================================\n# Main simulation\n# ============================================================\nif __name__ == "__main__":\n    print("\\n=== FLFM PSF Computation ===")\n\n    # First, do a quick test with small grid\n    print("\\n--- Quick test: PSF at z=0 ---")\n    t0 = time.time()\n    psf_z0, dx_cam = compute_flfm_psf((0, 0, 0), cam_npix=210, n_theta=60)\n    t1 = time.time()\n    print(f"  Time: {t1-t0:.1f} s")\n    print(f"  Camera pixel size: {dx_cam*1e6:.2f} μm (target: {P*1e6:.1f} μm)")\n    print(f"  PSF max: {psf_z0.max():.4e}, min: {psf_z0.min():.4e}")\n    print(f"  PSF shape: {psf_z0.shape}")\n\n    # Sanity check\n    assert not np.any(np.isnan(psf_z0))\n    assert psf_z0.max() > 0\n\n    # Compute PSF stack for reconstruction\n    # Depth range: -15 to 15 μm with 0.5 μm steps\n    z_range = np.arange(-15e-6, 15.5e-6, delta_z)\n    print(f"\\n--- Computing PSF stack: {len(z_range)} depths from {z_range[0]*1e6:.1f} to {z_range[-1]*1e6:.1f} μm ---")\n\n    t0 = time.time()\n    psf_stack, dx_cam = compute_psf_stack(z_range, cam_npix=210, n_theta=60)\n    t1 = time.time()\n    print(f"Total PSF computation time: {t1-t0:.1f} s")\n    print(f"PSF stack shape: {psf_stack.shape}")\n\n    # Save PSF stack\n    np.savez_compressed("psf_stack.npz", psf_stack=psf_stack, z_range=z_range, dx_cam=dx_cam)\n    print("PSF stack saved.")\n\n    # ============================================================\n    # Simulate and reconstruct a point emitter at z=0\n    # ============================================================\n    print("\\n=== Simulating point emitter at z=0 ===")\n\n    # Generate camera image for a point emitter at origin\n    camera_image = psf_stack[len(z_range)//2].copy()  # z=0\n    camera_image = camera_image / camera_image.max()\n\n    # Add small noise\n    noise_level = 0.001\n    camera_image += noise_level * np.random.randn(*camera_image.shape)\n    camera_image = np.maximum(camera_image, 0)\n\n    # Reconstruct\n    print("Running Richardson-Lucy deconvolution (5 iterations)...")\n    t0 = time.time()\n    recon = richardson_lucy_3d(camera_image, psf_stack, n_iter=5)\n    t1 = time.time()\n    print(f"Reconstruction time: {t1-t0:.1f} s")\n\n    # Measure FWHM\n    # Find peak location\n    peak_idx = np.unravel_index(np.argmax(recon), recon.shape)\n    print(f"Peak location (z, y, x): {peak_idx}")\n    print(f"Peak z = {z_range[peak_idx[0]]*1e6:.1f} μm")\n\n    # Lateral FWHM (in object space)\n    # The camera pixel maps to object space as: P/M_T per pixel, but our PSF\n    # is computed on a grid with pixel size dx_cam ≈ P\n    obj_pix = dx_cam / M_T  # object space pixel size\n\n    profile_x = recon[peak_idx[0], peak_idx[1], :]\n    profile_y = recon[peak_idx[0], :, peak_idx[2]]\n    profile_z = recon[:, peak_idx[1], peak_idx[2]]\n\n    fwhm_x = measure_fwhm(profile_x, obj_pix * 1e6)\n    fwhm_y = measure_fwhm(profile_y, obj_pix * 1e6)\n    fwhm_z = measure_fwhm(profile_z, delta_z * 1e6)\n\n    print(f"\\nFWHM measurements:")\n    print(f"  FWHM_x = {fwhm_x:.2f} μm (paper: ~2 μm)")\n    print(f"  FWHM_y = {fwhm_y:.2f} μm (paper: ~2 μm)")\n    print(f"  FWHM_z = {fwhm_z:.2f} μm (paper: ~4-5 μm)")\n    print(f"  Object pixel size: {obj_pix*1e6:.3f} μm")\n\n    # Save results\n    results = {\n        "fwhm_x_um": round(fwhm_x, 2),\n        "fwhm_y_um": round(fwhm_y, 2),\n        "fwhm_z_um": round(fwhm_z, 2),\n        "dx_cam_um": round(dx_cam * 1e6, 2),\n        "obj_pix_um": round(obj_pix * 1e6, 3),\n        "peak_z_um": round(z_range[peak_idx[0]] * 1e6, 1),\n        "n_iterations": 5,\n        "n_z_planes": len(z_range),\n    }\n\n    with open("reconstruction_results.json", "w") as f:\n        json.dump(results, f, indent=2)\n\n    # Save reconstruction\n    np.savez_compressed("reconstruction.npz", recon=recon, z_range=z_range,\n                         camera_image=camera_image, results=results)\n\n    print("\\nResults saved.")\n    print(f"\\nSummary: FWHM = ({fwhm_x:.2f}, {fwhm_y:.2f}, {fwhm_z:.2f}) μm")\n    print(f"Paper values: (~2.0, ~2.0, ~4.5) μm")\nPYEOF\n\n###PS1JSON###\n{\n  "pid": "",\n  "exit_code": "0",\n  "username": "yjh",\n  "hostname": "server3090",\n  "working_dir": "/home/yjh/openhands_workspace_v5/test_b1_run1_flfm_20260329_164220",\n  "py_interpreter_path": "/home/yjh/local_openhands_env/bin/python"\n}\n###PS1END###\necho "Simulation script created. Running..."\nSimulation script created. Running...\n\n###PS1JSON###\n{\n  "pid": "",\n  "exit_code": "0",\n  "username": "yjh",\n  "hostname": "server3090",\n  "working_dir": "/home/yjh/openhands_workspace_v5/test_b1_run1_flfm_20260329_164220",\n  "py_interpreter_path": "/home/yjh/local_openhands_env/bin/python"\n}\n###PS1END###\npython /home/yjh/openhands_workspace_v5/test_b1_run1_flfm_20260329_164220/flfm_simulation.py 2>&1\n^L=== System Parameters ===\nM_T = 8.96\nD_pupil = 3.5625 mm\nNA_ML = 0.017857\nR_xy = 2.12 μm\nFOV = 66.96 μm\nCamera pixel in object space = 0.725 μm\nDiffraction spot on camera = 19.0 μm = 2.9 pixels\nNumber of microlenses: 25\n\n=== FLFM PSF Computation ===\n\n--- Quick test: PSF at z=0 ---\ncd /home/yjh/openhands_workspace_v5/test_b1_run1_flfm_20260329_164220 && python flfm_simulation.py 2>&1\n  Time: 10.8 s\n  Camera pixel size: 6.50 μm (target: 6.5 μm)\n  PSF max: 2.2718e-17, min: 1.0358e-23\n  PSF shape: (210, 210)\n\n--- Computing PSF stack: 62 depths from -15.0 to 15.5 μm ---\n  Computing PSF at z = -15.0 μm...\n  Computing PSF at z = -14.5 μm...\n  Computing PSF at z = -14.0 μm...\n  Computing PSF at z = -13.5 μm...\n  Computing PSF at z = -13.0 μm...\n  Computing PSF at z = -12.5 μm...\n  Computing PSF at z = -12.0 μm...\n  Computing PSF at z = -11.5 μm...\n  Co